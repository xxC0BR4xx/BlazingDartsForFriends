@using BlazingDartsForFriends.Pages
@using Blazor.IndexedDB.Framework
@using Classes
@using System.Text.Json
@using global::Classes
@inject IndexedDbAccessor IndexedDbAccessor
@inject StateContainer StateContainer
@inject NavigationManager NavigationManager

<div class="add-player-overlay">
    <div class="add-player-modal">
        <div class="modal-header-custom">
            <h3>
                <Icon Name="IconName.UserPlus" />
                Add New Player
            </h3>
            <Button Color="Color.Light" @onclick="CloseModal" Class="close-btn">
                <Icon Name="IconName.Times" />
            </Button>
        </div>

        <div class="modal-body-custom">
            <div class="input-group-custom">
                <label for="playerName">
                    <Icon Name="IconName.User" />
                    Player Name
                </label>
                <InputText id="playerName" 
                          @bind-Value="newPlayerName" 
                          placeholder="Enter player name..."
                          class="player-name-input" />
            </div>

            <div class="button-group">
                <Button Color="Color.Secondary" @onclick="CloseModal" Class="cancel-btn">
                    <Icon Name="IconName.Times" />
                    Cancel
                </Button>
                <Button Color="Color.Primary" @onclick="AddPlayer" Class="add-btn" Disabled="@string.IsNullOrWhiteSpace(newPlayerName)">
                    <Icon Name="IconName.Check" />
                    Add Player
                </Button>
            </div>
        </div>
    </div>
</div>

@code {
    private string newPlayerName = "";

    public async Task AddPlayer()
    {
        if (string.IsNullOrWhiteSpace(newPlayerName))
            return;

        Player value = new Player(StateContainer.playerID, newPlayerName.Trim());
        await IndexedDbAccessor.SetValueAsync<Player>("players", value);

        StateContainer.playerID += 1;
        await IndexedDbAccessor.SetValueAtPositionAsync<int>("playerID", 0, StateContainer.playerID);

        newPlayerName = "";
        CloseModal();
    }

    private void CloseModal()
    {
        StateContainer.isAddPlayerComponentVisible = false;
        StateContainer.home?.render();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await GetPlayerIDAsync();
        }
    }

    public async Task GetPlayerIDAsync()
    {
        StateContainer.playerID = await IndexedDbAccessor.GetValueAsync<int>("playerID", 0);
    }
}
