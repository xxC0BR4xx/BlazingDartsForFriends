@using System.Text.Json
@using BlazingDartsForFriends.Models
@using Microsoft.JSInterop
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<div id="GameSettingsWrapper">
    <div class="settings-header">
        <Button Color="Color.Light" @onclick="GoBack" Size="Size.Small" Class="back-button-settings">
            <Icon Name="IconName.ArrowLeft" />
            Back
        </Button>
        <h2>Game Setup</h2>
    </div>

    <div class="settings-section">
        <h3>
            <Icon Name="IconName.Users" />
            Choose Players
        </h3>

        @if (StateContainer.Players.Any())
        {
            <div class="players-grid">
                @foreach (Player player in StateContainer.Players)
                {
                    <div class="player-card @(player.IsActive ? "active" : "")" @onclick="() => TogglePlayer(player)">
                        <div class="player-checkbox">
                            <InputCheckbox @bind-Value="player.IsActive" @onclick:stopPropagation="true" />
                        </div>
                        <div class="player-info">
                            <Icon Name="IconName.User" />
                            <span>@player.Name</span>
                        </div>
                        @if (player.IsActive)
                        {
                            <div class="active-badge">
                                <Icon Name="IconName.Check" />
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <Alert Color="Color.Info" Visible Class="no-players-alert">
                <Icon Name="IconName.InfoCircle" />
                <p>No players available. Add players first!</p>
                <Button Color="Color.Primary" @onclick="GoToAddPlayer">
                    <Icon Name="IconName.UserPlus" />
                    Add Players
                </Button>
            </Alert>
        }
    </div>

    <div class="settings-section">
        <h3>
            ⚙️ Game Settings
        </h3>

        <div class="game-settings-grid">
            <div class="setting-card">
                <label>
                    <Icon Name="IconName.Play" />
                    Game Mode
                </label>
                <Select @bind-SelectedValue="@StateContainer.CurrentGameSettings.GameMode" Class="custom-select">
                    <SelectItem Value="GameMode.X01">X01</SelectItem>
                    <SelectItem Value="GameMode.Cricket">Cricket</SelectItem>
                    <SelectItem Value="GameMode.AroundTheClock">Around the Clock</SelectItem>
                </Select>
            </div>

            @if (StateContainer.CurrentGameSettings.GameMode == GameMode.X01)
            {
                <div class="setting-card">
                    <label>
                        <Icon Name="IconName.Dashboard" />
                        Starting Score
                    </label>
                    <Select @bind-SelectedValue="@StateContainer.CurrentGameSettings.StartingScore" Class="custom-select">
                        <SelectItem Value="101">101</SelectItem>
                        <SelectItem Value="301">301</SelectItem>
                        <SelectItem Value="501">501</SelectItem>
                        <SelectItem Value="701">701</SelectItem>
                    </Select>
                </div>

                <div class="setting-card">
                    <label>
                        <Icon Name="IconName.Flag" />
                        Checkout Mode
                    </label>
                    <Select @bind-SelectedValue="@StateContainer.CurrentGameSettings.CheckoutMode" Class="custom-select">
                        <SelectItem Value="CheckoutMode.SingleOut">Single Out</SelectItem>
                        <SelectItem Value="CheckoutMode.DoubleOut">Double Out</SelectItem>
                        <SelectItem Value="CheckoutMode.MasterOut">Master Out</SelectItem>
                    </Select>
                </div>
            }
        </div>
    </div>

    <Button Color="Color.Success" @onclick="StartGame" Class="start-game-button" Disabled="@(!StateContainer.Players.Any(p => p.IsActive))">
        <Icon Name="IconName.Play" />
        Start Game
    </Button>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await GetPlayerIDAsync();
        await LoadPlayers();
        StateContainer.game?.render();
    }

    private async Task LoadPlayers()
    {
        StateContainer.Players.Clear();

        for (int i = 0; i < StateContainer.playerID; i++)
        {
            await GetValueAsync(i);
        }

        StateContainer.game?.render();
    }

    public async Task GetPlayerIDAsync()
    {
        StateContainer.playerID = await IndexedDbAccessor.GetValueAsync<int>("playerID", 0);
    }

    public async Task GetValueAsync(int i)
    {
        JsonDocument storedPlayer = await IndexedDbAccessor.GetValueAsync<JsonDocument>("players", i);
        string name = storedPlayer.RootElement.GetProperty("name").GetString() ?? "";
        StateContainer.Players.Add(new Player(i, name));
    }

    private void TogglePlayer(Player player)
    {
        player.IsActive = !player.IsActive;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("./BlazingDartsForFriends/");
    }

    private void GoToAddPlayer()
    {
        NavigationManager.NavigateTo("./BlazingDartsForFriends");
        StateContainer.isAddPlayerComponentVisible = true;
    }

    public void StartGame()
    {
        StateContainer.activePlayers.Clear();

        foreach (Player player in StateContainer.Players)
        {
            if (player.IsActive)
            {
                StateContainer.activePlayers.Add(player);
            }
        }

        if (StateContainer.activePlayers.Count == 0)
        {
            return;
        }

        StateContainer.CurrentGameSettings.PlayerIds = StateContainer.activePlayers.Select(p => p.Id).ToList();
        StateContainer.GameService.StartNewGame(StateContainer.CurrentGameSettings, StateContainer.activePlayers);

        StateContainer.isGameOver = false;
        StateContainer.game?.render();
    }
}
